---
layout: base.njk
---

<article class="post-wrap">

  <a href="/blog/" class="back-link">
    &#8592; All posts
  </a>

  <header class="post-header">
    <div class="post-header-meta">
      <time datetime="{{ page.date }}">{{ page.date | dateFormat }}</time>
      {% if tags %}
        {% for tag in tags %}
          {% if tag != "posts" %}
            <span class="tag">{{ tag }}</span>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
    <h1>{{ title }}</h1>
    {% if description %}
      <p class="post-header-desc">{{ description }}</p>
    {% endif %}
  </header>

  <div class="prose">
    {{ content | safe }}
  </div>

  <div class="giscus-wrap">
    <script src="https://giscus.app/client.js"
            data-repo="dnewcome/aibuilderblog.com"
            data-repo-id="R_kgDORmcrrw"
            data-category="Announcements"
            data-category-id="DIC_kwDORmcrr84C4XB0"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="dark"
            data-lang="en"
            data-loading="lazy"
            crossorigin="anonymous"
            async>
    </script>
  </div>

</article>
